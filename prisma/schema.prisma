// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  stack       String      // JSON string: { frontend, backend, database }
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  canvasHeight     Int         @default(900)
  canvasBackground String?     // "solid:#ffffff" or "gradient:linear-gradient(...)"
  components       Component[]
}

model Component {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // "Button" | "Input" | "Card" | "Navbar" | "Hero" | "Text" | "Image"
  label     String
  props     String   // JSON string
  logic     String?  // JS/TS code
  position  Int      @default(0)
  x         Int?
  y         Int?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}
